{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",              // ✅ ESM
    "moduleResolution": "node",      // ⚠️ NOT bundler
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["server.ts"]
}